<?xml version="1.0" encoding="utf-8"?>
<!--
  Nextpeyk App Icon — Background Layer
  Radial gradient: #1c2d40 (centre-top, 48%×36%) → #060a0f (edges)
  + central blue ambient glow ellipse (simulates radialGradient glow at 12% opacity)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dark radial gradient background -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="51.84"
                android:centerY="38.88"
                android:gradientRadius="73.44"
                android:startColor="#1C2D40"
                android:endColor="#060A0F"/>
        </aapt:attr>
    </path>

    <!-- Central blue ambient glow (cx=48% cy=43%, rx≈54 ry≈50 of 108) -->
    <!-- Approximated as large low-opacity ellipse — simulates radialGradient glow at 12% -->
    <path
        android:fillColor="#1E246FA3"
        android:pathData="M54,46 m-54,0 a54,48 0 1,0 108,0 a54,48 0 1,0 -108,0 Z"/>

</vector>
