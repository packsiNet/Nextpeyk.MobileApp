<?xml version="1.0" encoding="utf-8"?>
<!--
  Nextpeyk App Icon — Foreground Layer
  N letterform, 60% scale centred in 1024×1024 viewport.
  Left vertical:  x=368, y=333→691
  Right vertical: x=656, y=333→691
  Diagonal:       (368,333)→(656,691)
  Blue dots both at TOP corners: (368,333) and (656,333)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="1024"
    android:viewportHeight="1024">

    <!-- Ambient glow behind N -->
    <path
        android:fillColor="#00000000"
        android:pathData="M368,691 L368,333 L656,691 L656,333"
        android:strokeColor="#1A246FA3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="110"/>

    <!-- Left vertical stroke -->
    <path
        android:fillColor="#00000000"
        android:pathData="M368,691 L368,333"
        android:strokeColor="#F2FFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="50"/>

    <!-- Right vertical stroke -->
    <path
        android:fillColor="#00000000"
        android:pathData="M656,691 L656,333"
        android:strokeColor="#F2FFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="50"/>

    <!-- Diagonal stroke — lighter layer -->
    <path
        android:fillColor="#00000000"
        android:pathData="M368,333 L656,691"
        android:strokeColor="#8CFFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="50"/>

    <!-- Diagonal stroke — brighter layer -->
    <path
        android:fillColor="#00000000"
        android:pathData="M368,333 L656,691"
        android:strokeColor="#B3FFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="50"/>

    <!-- Motion dots along diagonal: t=1/3, 1/2, 2/3 -->
    <!-- t=1/3: (464, 452) r=13 -->
    <path
        android:fillColor="#2EFFFFFF"
        android:pathData="M451,452 A13,13,0,1,0,477,452 A13,13,0,1,0,451,452 Z"/>
    <!-- t=1/2: (512, 512) r=10 -->
    <path
        android:fillColor="#1EFFFFFF"
        android:pathData="M502,512 A10,10,0,1,0,522,512 A10,10,0,1,0,502,512 Z"/>
    <!-- t=2/3: (560, 572) r=7 -->
    <path
        android:fillColor="#14FFFFFF"
        android:pathData="M553,572 A7,7,0,1,0,567,572 A7,7,0,1,0,553,572 Z"/>

    <!-- ── LEFT TOP DOT (368, 333) ── -->
    <!-- Glow halo r=54 -->
    <path
        android:fillColor="#2E246FA3"
        android:pathData="M314,333 A54,54,0,1,0,422,333 A54,54,0,1,0,314,333 Z"/>
    <!-- Dot gradient fill r=34 -->
    <path android:pathData="M334,333 A34,34,0,1,0,402,333 A34,34,0,1,0,334,333 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="368"
                android:centerY="333"
                android:gradientRadius="34"
                android:startColor="#4ea8de"
                android:endColor="#1a5c8a"
                android:type="radial"/>
        </aapt:attr>
    </path>
    <!-- White ring -->
    <path
        android:fillColor="#00000000"
        android:pathData="M334,333 A34,34,0,1,0,402,333 A34,34,0,1,0,334,333 Z"
        android:strokeColor="#B3FFFFFF"
        android:strokeWidth="7"/>

    <!-- ── RIGHT TOP DOT (656, 333) ── -->
    <!-- Glow halo r=54 -->
    <path
        android:fillColor="#2E246FA3"
        android:pathData="M602,333 A54,54,0,1,0,710,333 A54,54,0,1,0,602,333 Z"/>
    <!-- Dot gradient fill r=34 -->
    <path android:pathData="M622,333 A34,34,0,1,0,690,333 A34,34,0,1,0,622,333 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="656"
                android:centerY="333"
                android:gradientRadius="34"
                android:startColor="#4ea8de"
                android:endColor="#1a5c8a"
                android:type="radial"/>
        </aapt:attr>
    </path>
    <!-- White ring -->
    <path
        android:fillColor="#00000000"
        android:pathData="M622,333 A34,34,0,1,0,690,333 A34,34,0,1,0,622,333 Z"
        android:strokeColor="#B3FFFFFF"
        android:strokeWidth="7"/>

    <!-- Subtle top-left shine -->
    <path
        android:fillColor="#07FFFFFF"
        android:pathData="M-20,80 A200,160,0,0,1 360,0 L360,0 A200,160,0,0,0 -20,80 Z"/>

</vector>
